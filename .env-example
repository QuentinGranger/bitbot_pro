# Configuration de la base de données
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bitbotpro
DB_USER=postgres
DB_PASSWORD=password

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Configuration Telegram pour les notifications
TELEGRAM_BOT_TOKEN=votre_token_bot_telegram_ici
TELEGRAM_CHAT_IDS=votre_chat_id_ici
TELEGRAM_MIN_PRIORITY=LOW
TELEGRAM_RATE_LIMIT=60

# Configuration du logger
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=/var/log/bitbotpro/app.log

# Configuration du serveur
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# Configuration des websockets
WS_RECONNECT_DELAY=1  # Délai initial de reconnexion (secondes)
WS_MAX_RECONNECT_ATTEMPTS=5  # Nombre max de tentatives de reconnexion
WS_BACKOFF_FACTOR=2  # Facteur d'augmentation du délai entre tentatives
WS_MAX_BACKOFF_DELAY=60  # Délai maximum entre tentatives (secondes)
